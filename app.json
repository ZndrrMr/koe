{
  "expo": {
    "name": "Koe",
    "slug": "koe",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "koe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zndrr.koe",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Koe needs the microphone to hear your Japanese so we can coach your pronunciation and pitch accent.",
        "UIBackgroundModes": ["audio"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zndrr.koe",
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-sqlite", { "enableFTS": true }],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Koe to access your microphone."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false },
      "workerUrl": null
    }
  }
}
